model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @map("tenant_id") @db.VarChar(64)
  branchId    String?   @map("branch_id") @db.VarChar(64)
  userId      String?   @map("user_id") @db.VarChar(80)
  actorId     String?   @map("actor_id") @db.Uuid
  sessionId   String?   @map("session_id") @db.Uuid
  action      String    @db.VarChar(120)
  entity      String?   @db.VarChar(120)
  entityId    String?   @map("entity_id") @db.VarChar(80)
  ip          String?   @db.VarChar(80)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  requestId   String?   @map("request_id") @db.VarChar(120)
  before      Json?
  after       Json?
  metadata    Json      @default("{}")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant      Tenant?   @relation(fields: [tenantId], references: [tenantId], onDelete: SetNull, onUpdate: Cascade)
  branch      Branch?   @relation(fields: [tenantId, branchId], references: [tenantId, branchId], onDelete: SetNull, onUpdate: Cascade)
  actor       User?     @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, branchId])
  @@index([tenantId, actorId])
  @@index([tenantId, sessionId])
  @@index([tenantId, deletedAt])
  @@index([action])
  @@map("audit_logs")
}

