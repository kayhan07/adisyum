# Adisyum production environment
# Copy to /root/adisyum/.env.production on the VPS and replace every CHANGE_ME value.

# Core runtime
NODE_ENV=production
APP_ENV=production
NEXT_PUBLIC_APP_URL=https://adisyum.com
ADISYUM_ROOT_ASSET_PREFIX=/adisyum-root-assets

# Database - REQUIRED
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_DATABASE?schema=public
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECT_TIMEOUT_MS=10000
SLOW_QUERY_THRESHOLD_MS=300

# Auth/session - REQUIRED
# Use the same high-entropy value for both to support current and common Next auth naming.
ADISYUM_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
NEXTAUTH_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
ADISYUM_SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Bootstrap defaults - REQUIRED for deterministic initial admin recovery
BOOTSTRAP_TENANT_ID=ABN-48291
BOOTSTRAP_BRANCH_ID=mrk
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Redis / cache / realtime - REQUIRED in production by cache and tenant realtime modules
UPSTASH_REDIS_REST_URL=https://CHANGE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=CHANGE_ME_UPSTASH_TOKEN

# Uploads/assets
UPLOAD_ROOT_DIR=/root/adisyum/public/uploads

# Secret used to encrypt stored GIB credentials
GIB_CREDENTIAL_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG

# Optional backend bridge integration
AURELIA_API_URL=http://127.0.0.1:8000
AURELIA_TENANT_KEY=default
AURELIA_BACKEND_EMAIL=admin@aurelia.local
AURELIA_BACKEND_PASSWORD=CHANGE_ME_BACKEND_PASSWORD

# Optional realtime client config
WEBSOCKET_URL=
NEXT_PUBLIC_WEBSOCKET_URL=
NEXT_PUBLIC_KDS_APP_KEY=
NEXT_PUBLIC_KDS_WS_HOST=
NEXT_PUBLIC_KDS_WS_SCHEME=https
NEXT_PUBLIC_KDS_WS_PORT=443
NEXT_PUBLIC_KDS_APP_CLUSTER=mt1

# Optional Windows installer website metadata
NEXT_PUBLIC_ADISYUM_WINDOWS_VERSION=Latest stable
NEXT_PUBLIC_ADISYUM_WINDOWS_INSTALLER_SIZE=Signed package
NEXT_PUBLIC_ADISYUM_WINDOWS_INSTALLER_URL=

# Optional backup and alerting
BACKUP_ROOT_DIR=/root/adisyum/backups
BACKUP_RETENTION_DAYS=14
BACKUP_FULL_INTERVAL_MIN=360
BACKUP_INCREMENTAL_INTERVAL_MIN=30
BACKUP_ENCRYPTION_KEY=
ALERT_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=
