{
  "name": "@adisyum/desktop",
  "private": true,
  "version": "0.1.2",
  "description": "Adisyum Desktop shell for Windows restaurant operations",
  "author": "Adisyum",
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.adisyum.desktop",
    "productName": "Adisyum Desktop",
    "artifactName": "AdisyumDesktopSetup.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://adisyum.com/downloads/windows/latest/"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Adisyum Desktop"
    }
  }
}
